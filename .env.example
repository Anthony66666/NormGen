# Copy to .env or export these variables before running scripts.

# Processed combined NPZ used by train_combined.py.
COMBINED_PATH=data/interaction_multi_train_combined.npz

# Raw INTERACTION-Dataset-DR-multi-v1_2 root used by data_preprocess.py.
INTERACTION_ROOT=/path/to/INTERACTION-Dataset-DR-multi-v1_2

# prediction or initialization
MODE=prediction

# Set to 2+ to use torchrun through scripts/train.sh.
NUM_GPUS=
LAUNCHER=auto

# Optional preprocessing controls.
SPLIT=train
OUTPUT_DIR=data/processed_train

# AutoBots integration.
PYTHON_BIN=python
AUTOBOTS_ROOT=../AutoBots
AUTOBOTS_DATASET_DIR=autobots_data/normgen_generated
SERVER_WORK_DIR=server_workspace
INTERACTION_MAPS_ROOT=/path/to/INTERACTION-Dataset-DR-multi-v1_2/maps
NORMGEN_NPZ=/path/to/000001_interaction_combined_samples.npz
VAL_RATIO=0.1
SAMPLE_KEY=conditional_samples
MODE_INDEX=-1
USE_MAP_LANES=0
AUTOBOTS_EPOCHS=50
AUTOBOTS_BATCH_SIZE=64
SMOKE_MAX_SCENES=4
